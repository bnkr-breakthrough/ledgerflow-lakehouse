# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ledgerflowdb
POSTGRES_USER=ledgerflow
POSTGRES_PASSWORD=ledgerflow123

# ─── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPICS=ledgerflow.public.customers,ledgerflow.public.loans,ledgerflow.public.transactions

# ─── Azure Data Lake Storage Gen2 ───────────────────────────────────────────
ADLS_ACCOUNT_NAME=ledgerflowadls
ADLS_ACCOUNT_KEY=your_adls_account_key_here
ADLS_CONTAINER_NAME=raw

# ─── Debezium ───────────────────────────────────────────────────────────────
DEBEZIUM_HOST=localhost
DEBEZIUM_PORT=8083
